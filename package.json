{
  "name": "keyflow-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Rain Design Labs KeyFlow — AI-first CRM for small business",
  "scripts": {
    "dev": "tsx watch src/backend/index.ts",
    "build": "pnpm dashboard:build && pnpm build:backend",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx drizzle/migrate.ts",
    "user:add": "tsx scripts/manage-users.ts add",
    "user:passwd": "tsx scripts/manage-users.ts passwd",
    "user:list": "tsx scripts/manage-users.ts list",
    "user:remove": "tsx scripts/manage-users.ts remove",
    "user:role": "tsx scripts/manage-users.ts role",
    "db:setup": "pnpm db:generate && pnpm db:migrate",
    "db:reset": "tsx src/backend/seed.ts",
    "test:api": "tsx scripts/test-api.ts",
    "dashboard:dev": "vite --config src/frontend/dashboard/vite.config.ts",
    "dashboard:build": "vite build --config src/frontend/dashboard/vite.config.ts",
    "build:backend": "tsc"
  },
  "dependencies": {
    "@fastify/auth": "^5.0.4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^9.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "googleapis": "^144.0.0",
    "nodemailer": "^6.10.0",
    "postgres": "^3.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^5.12.0",
    "twilio": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
